[flake8]
# Pydantic-specific linting via flake8-pydantic
# Async anti-pattern detection via flake8-async

# Only enable Pydantic and Async rules (other linting via ruff)
select = PYD,ASYNC
extend-exclude = .venv,build,dist,.uv-cache

# LangGraph's @auth.authenticate / @auth.on require async handler signatures even when
# the body never awaits, so flake8-async's "could be sync" (ASYNC124) and missing-checkpoint
# (ASYNC910) checks are false positives here. ruff's equivalent RUF029 is suppressed inline.
per-file-ignores =
    src/sample_db/auth.py:ASYNC124,ASYNC910
