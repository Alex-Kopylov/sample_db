# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: chat model used by the agent (default: gpt-5.4-mini)
# MODEL=gpt-5.4-mini

# Optional: SQLite database path (default: data/app.db)
# DB_PATH=data/app.db
