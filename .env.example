# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Required: Postgres connections.
#   PG_APP_DSN  -> sample_app role: RLS-enforced, SELECT-only (all agent queries).
#   PG_AUTH_DSN -> sample_auth role: resolves authenticated email -> customer id only.
# These dev credentials match db/00_roles.sql; use a secret manager in production.
PG_APP_DSN=postgresql://sample_app:sample_app_pw@127.0.0.1:5432/sample_db
PG_AUTH_DSN=postgresql://sample_auth:sample_auth_pw@127.0.0.1:5432/sample_db

# Required: JWT signing/verification (HS256). Use a strong secret in production.
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256

# Optional: chat model used by the agent (default: gpt-5.4-mini)
# MODEL=gpt-5.4-mini
